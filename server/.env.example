# Copy to .env and fill in real values
PORT=5000
NODE_ENV=development

# Allowed origin(s) for the Vercel frontend (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000,https://hope-pdf.vercel.app

# Google OAuth
#  - CLIENT_ID is enough for ID-token verification (front-end GIS pop-up)
#  - CLIENT_SECRET + JWT_SECRET + FRONTEND_URL are needed for the
#    server-side OAuth redirect flow (GET /auth/google → callback → JWT)
GOOGLE_CLIENT_ID=165450201442-6f6ls3vsn41r5qlk3v5089pro7h0l625.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=
JWT_SECRET=change_me_to_a_long_random_string
FRONTEND_URL=https://hopepdf-oli69fhk9-hopepdfs-projects.vercel.app

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxx

# Plan caps
FREE_MAX_FILE_MB=20
PREMIUM_MAX_FILE_MB=100
FREE_HOURLY_QUOTA=5
PREMIUM_HOURLY_QUOTA=200
